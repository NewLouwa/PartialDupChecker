id: partial_dup_checker
name: Partial Duplicate Checker
metadata:
  description: Detects partial video duplicates (cuts, parts, montages) that Stash's whole-file phash duplicate finder misses. Builds a per-scene perceptual-hash timeline, indexes segments with LSH bands, aligns candidate pairs to localize matched time-ranges, and classifies into Duplicate / Part / Cut-Montage. Separate from and complementary to the built-in duplicate checker; opt-in write-back only.
  version: 0.1.0
  date: "2026-06-16"
  requires: []
files:
  - partialdup_checker.yml
  - partialdup.js
  - partialdup.css
  - partialdup.py
